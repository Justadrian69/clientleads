---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact — ClientLeads.io"
  description="Get in touch with ClientLeads. We respond within 24 hours."
>
  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">Client<span>Leads</span>.io</a>
    <ul class="nav-links">
      <li><a href="/#services">Services</a></li>
      <li><a href="/#how">How It Works</a></li>
      <li><a href="/#pricing">Pricing</a></li>
      <li><a href="/#testimonials">Reviews</a></li>
      <li><a href="/contact" style="color:var(--text);">Contact</a></li>
    </ul>
    <a href="/contact" class="nav-cta">Get My Website</a>
  </nav>

  <!-- STARS -->
  <div style="position:fixed;inset:0;pointer-events:none;z-index:0;" id="starfield"></div>

  <!-- PAGE HERO -->
  <div class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-grid"></div>
    <div class="section-eyebrow" style="justify-content:center;display:flex;">Contact Us</div>
    <h1 class="page-hero" style="padding:0;background:none;">Get In Touch</h1>
  </div>

  <!-- CONTACT SECTION -->
  <div class="contact-section">
    <div class="contact-grid">

      <!-- Left: info -->
      <div class="contact-info">
        <div class="contact-info-eyebrow">Contact Us</div>
        <h2>Let's Build Your Pipeline</h2>
        <p class="contact-info-desc">
          Send us a message and let us know everything you want out of a new site. We respond to
          everyone within 24 hours of contacting us. Or give us a call and reach us immediately for
          a chat — if we're unavailable we'll call back same day.
        </p>

        <div class="contact-items">
          <div class="contact-item">
            <div class="contact-item-icon">📞</div>
            <div>
              <div class="contact-item-label">Phone</div>
              <div class="contact-item-value">
                <a href="tel:+12155550100">(215) 555-0100</a>
              </div>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">✉️</div>
            <div>
              <div class="contact-item-label">Email</div>
              <div class="contact-item-value">
                <a href="mailto:hello@clientleads.io">hello@clientleads.io</a>
              </div>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">📍</div>
            <div>
              <div class="contact-item-label">Areas Served</div>
              <div class="contact-item-value">USA & Canada</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-form-card">
        <h3>Make Appointment</h3>
        <form
          name="contact"
          method="POST"
          data-netlify="true"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Alex Johnson" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="alex@company.com" required />
            </div>
          </div>

          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" />
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea
              id="message"
              name="message"
              placeholder="Tell us about your business and what you're looking for..."
              required
            ></textarea>
          </div>

          <button type="submit" class="form-submit">Send Message →</button>
        </form>
      </div>

    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="footer-grid">
      <div>
        <div class="footer-brand-name">Client<span>Leads</span>.io</div>
        <p class="footer-tagline">
          Done-for-you websites and digital growth for local service businesses. Built to rank,
          built to convert.
        </p>
        <a href="/contact" class="btn-primary" style="font-size:12px;padding:10px 20px;">
          Get Started Today
        </a>
      </div>
      <div class="footer-col">
        <h5>Services</h5>
        <ul>
          <li><a href="/#services">Website Build</a></li>
          <li><a href="/#services">GHL Setup</a></li>
          <li><a href="/#services">Local SEO</a></li>
          <li><a href="/#services">Paid Ads</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Company</h5>
        <ul>
          <li><a href="#">About</a></li>
          <li><a href="#">Portfolio</a></li>
          <li><a href="/#testimonials">Reviews</a></li>
          <li><a href="#">Blog</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Contact</h5>
        <ul>
          <li><a href="/contact">Make Appointment</a></li>
          <li><a href="mailto:hello@clientleads.io">hello@clientleads.io</a></li>
          <li><a href="#">Instagram</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} ClientLeads.io. All rights reserved.</p>
      <p>Built for local service pros.</p>
    </div>
  </footer>
</Layout>

<script>
  // Starfield
  const sf = document.getElementById("starfield");
  if (sf) {
    for (let i = 0; i < 120; i++) {
      const s = document.createElement("div");
      const size = Math.random() * 2 + 0.5;
      s.className = "star";
      s.style.cssText = `
        width:${size}px;height:${size}px;
        top:${Math.random() * 100}%;left:${Math.random() * 100}%;
        --o:${Math.random() * 0.5 + 0.1};
        --d:${Math.random() * 4 + 2}s;
        animation-delay:${Math.random() * 4}s;
      `;
      sf.appendChild(s);
    }
  }
</script>
